COMPRESS_API_KEY=

# Optional: override the built-in incident triage system prompt (otherwise agent.py default is used).
# AGENT_SYSTEM_PROMPT=

# When using POST /api/v2/complete, append model/provider/cost/compression lines to the assistant reply (good for demos).
COMPRESS_APPEND_META_FOOTER=true

# Default: LightReach native completion endpoint (compression + routing metadata).
COMPRESS_V2_URL=https://compress.lightreach.io/api/v2/complete

# Optional: OpenAI-compatible surface (set COMPRESS_USE_OPENAI_COMPAT=1 to use it).
COMPRESS_OPENAI_BASE_URL=https://api.compress.lightreach.io/v1
COMPRESS_USE_OPENAI_COMPAT=0

COMPRESS_MODEL=lightreach
COMPRESS_DESIRED_HLE=25
COMPRESS_COMPRESS=true
COMPRESS_LLM_PROVIDER=
COMPRESS_REQUEST_TIMEOUT=120
COMPRESS_TAG_TEAM=platform
COMPRESS_TAG_ENVIRONMENT=development
COMPRESS_TAG_FEATURE=idun-agent
